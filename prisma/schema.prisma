generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id              Int          @id @default(autoincrement())
  name            String
  email           String       @unique
  password        String
  role            String       @default("ATTENDEE")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  events          Event[]      @relation("OrganizerEvents")
  bookings        Booking[]
  tickets         Ticket[]
  attendance      Attendance[] @relation("ScannedBy")
  reviews         Review[]

  @@map("users")
}

model Event {
  id              Int          @id @default(autoincrement())
  title           String
  description     String?      @db.NVarChar(Max)
  venue           String?
  eventDate       DateTime     @map("event_date")
  totalSeats      Int          @map("total_seats")
  availableSeats  Int          @map("available_seats")
  price           Float
  status          String       @default("DRAFT")
  organizerId     Int          @map("organizer_id")
  imageUrl        String?      @map("image_url")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  organizer       User         @relation("OrganizerEvents", fields: [organizerId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  bookings        Booking[]
  tickets         Ticket[]
  attendance      Attendance[]
  reviews         Review[]

  @@map("events")
}

model Booking {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  eventId         Int      @map("event_id")
  status          String   @default("PENDING")
  totalAmount     Float    @map("total_amount")
  ticketCount     Int      @map("ticket_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  event           Event    @relation(fields: [eventId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  user            User     @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  payment         Payment?
  tickets         Ticket[]

  @@map("bookings")
}

model Payment {
  id              Int      @id @default(autoincrement())
  bookingId       Int      @unique @map("booking_id")
  amount          Float
  status          String   @default("PENDING")
  stripePaymentId String?  @map("stripe_payment_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  booking         Booking  @relation(fields: [bookingId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("payments")
}

model Ticket {
  id          Int        @id @default(autoincrement())
  bookingId   Int        @map("booking_id")
  eventId     Int        @map("event_id")
  userId      Int        @map("user_id")
  qrCode      String     @unique @map("qr_code")
  seatNumber  String?    @map("seat_number")
  status      String     @default("ACTIVE")
  createdAt   DateTime   @default(now()) @map("created_at")
  attendance  Attendance?
  booking     Booking    @relation(fields: [bookingId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  event       Event      @relation(fields: [eventId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  user        User       @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("tickets")
}

model Attendance {
  id            Int      @id @default(autoincrement())
  ticketId      Int?     @unique @map("ticket_id")
  eventId       Int?     @map("event_id")
  scannedBy     Int      @map("scanned_by")
  status        String   @default("PRESENT")
  scannedAt     DateTime @default(now()) @map("scanned_at")
  notes         String?
  event         Event?   @relation(fields: [eventId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  scannedByUser User     @relation("ScannedBy", fields: [scannedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  ticket        Ticket?  @relation(fields: [ticketId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("attendance")
}

model Review {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  eventId        Int      @map("event_id")
  reviewText     String   @map("review_text") @db.NVarChar(Max)
  sentimentLabel String?  @map("sentiment_label")
  sentimentScore Float?   @map("sentiment_score")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  event          Event    @relation(fields: [eventId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("reviews")
}